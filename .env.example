# Canvas Chat AI - Environment Variables Template
# This file shows all required environment variables for local development

# ==============================================
# BACKEND ENVIRONMENT (.env in backend folder)
# ==============================================

# Required: Groq API key for LLaMA 3.3 70B model
GROQ_API_KEY=your_groq_api_key_here

# Required: Google Gemini API key for embeddings (free tier)
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Pinecone API key and index for vector storage
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=kuro-memory

# Required: MongoDB connection string
MONGODB_URI=your_mongodb_connection_string

# Optional: Environment configuration
ENVIRONMENT=development
DEBUG=True
PORT=8000

# Optional: Frontend URL for CORS
FRONTEND_URL=https://your-frontend-domain.com

# ==============================================
# FRONTEND ENVIRONMENT (.env in frontend folder)
# ==============================================

# Clerk Authentication (Get from clerk.com dashboard)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Backend API URL
# Local development: http://localhost:8000
# Production: https://your-backend-url.com
VITE_API_URL=http://localhost:8000

# ==============================================
# BACKEND ENVIRONMENT (.env in backend folder)
# ==============================================

# Database Connections (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your-chatbot-memory

# AI Service (Required)
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative name for compatibility (same value as GEMINI_API_KEY)
GOOGLE_API_KEY=your_gemini_api_key_here

# Authentication (Required)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Production Configuration
ENVIRONMENT=development
DEBUG=true
PORT=8000

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-frontend-url.vercel.app

# ==============================================
# SETUP INSTRUCTIONS
# ==============================================

# Get API Keys:
# - MongoDB: https://cloud.mongodb.com
# - Pinecone: https://pinecone.io
# - Google Gemini: https://makersuite.google.com/app/apikey
# - Clerk: https://clerk.com

# Instructions:
# 1. Copy this file to frontend/.env and backend/.env
# 2. Replace all placeholder values with your actual API keys
# 3. Set DEBUG=false and ENVIRONMENT=production for deployment
# 4. Never commit the .env file to version control
